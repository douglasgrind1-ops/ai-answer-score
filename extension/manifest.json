{
  "manifest_version": 3,
  "name": "AI Answer Score - Trust AI Answers",
  "version": "1.0.0",
  "description": "Score AI answers, detect risks, and generate stronger follow-up prompts instantly.",
  "permissions": [ ],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://www.aianswerscore.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "AI Answer Score"
  },
  "homepage_url": "https://www.aianswerscore.com"
}
